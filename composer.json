{
    "name": "slimapi/modular-monolith",
    "description": "Slim 4 modular monolith API with PHP-DI, OpenAPI, JWT, and PDO",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Maxsoft"
        }
    ],
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.13",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "monolog/monolog": "^3.6",
        "vlucas/phpdotenv": "^5.6",
        "zircote/swagger-php": "^4.11",
        "jimtools/jwt-auth": "^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "openapi:generate": "@php scripts/generate-openapi.php"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
