# Środowisko aplikacji (development | production)
APP_ENV=development
# Szczegóły błędów w odpowiedziach JSON (true tylko lokalnie)
APP_DEBUG=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=slim_api
DB_USER=root
DB_PASSWORD=

LOG_PATH=logs/app.log

# Tajny klucz podpisu JWT (min. 32 znaki w produkcji)
JWT_SECRET=change-this-to-a-long-random-secret-key-min-32-chars
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=https://api.example.com

# Limit żądań na adres IP w podanym oknie czasu (middleware rate limit)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60
